<?xml version="1.0" encoding="UTF-8"?>
<tags xmlns="http://hp.com/uca/expert/filter/tags" xmlns:jxb="http://java.sun.com/xml/ns/jaxb"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	<groups>
		<!-- Configuración global de parámetros para hwmasivov2,
		     siguiendo la estructura de CorteFibraV10 -->
		<group name="tags-config">
			<paramTags>
				<!-- Número mínimo de alarmas NE Is Disconnected para agrupar -->
				<paramTag name="NumAlarmsNeDisconnected" type="numeric" default="10"/>
				<!-- Ventana de tiempo en segundos para considerar alarmas NE Is Disconnected -->
				<paramTag name="SecondsToConsiderNeDisconnected" type="numeric" default="60"/>
				<!-- Edad máxima en segundos para considerar una alarma NE Is Disconnected (semilla o hija) -->
				<paramTag name="SecondsMaxAgeForNeAlarm" type="numeric" default="43200"/>
				<!-- Namespace de la instancia TeMIP (ej. vtemiplab_ns). Se usa al construir identificadores C:TeMIP y MASTER:TeMIP -->
				<paramTag name="TeMIPNamespace" type="string" default="vtemiplab_ns"/>
				<!-- Tiempo en segundos de espera tras llegar la PA antes de crear el TT (tolerancia, como MsToleranceForTT en CorteFibraV10) -->
				<paramTag name="SecondsToleranceForTT" type="numeric" default="120"/>
				<!-- Habilita creación de TT para la PA (1 = habilitado, 0 = deshabilitado) -->
				<paramTag name="CreateTTEnabled" type="numeric" default="1"/>
				<!-- Registro TT en BD: 1 = persistir en SQLite, 0 = no registrar -->
				<paramTag name="TTRegistryEnabled" type="numeric" default="1"/>
				<!-- URL JDBC SQLite (ej. jdbc:sqlite:tt_incident.db o ruta absoluta) -->
				<paramTag name="TTRegistryJdbcUrl" type="string" default="jdbc:sqlite:tt_incident.db"/>
				<!-- Nombre de la tabla de registro (por defecto UCA_TT_INCIDENT) -->
				<paramTag name="TTRegistryTableName" type="string" default="UCA_TT_INCIDENT"/>
				<!-- Segundos que la alarma NE Is Disconnected debe llevar en WM antes de ser evaluada para agrupación (ej. 900 = 15 min) -->
				<paramTag name="WaitBeforeGroupingSec" type="numeric" default="900"/>
			</paramTags>
		</group>
	</groups>
</tags>
