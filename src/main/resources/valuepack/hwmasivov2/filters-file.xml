<?xml version="1.0" encoding="UTF-8" ?>
<filters xmlns="http://hp.com/uca/expert/filter">

   <!--
      Filtro de configuración de tags para hwmasivov2,
      siguiendo la estructura de CorteFibraV10.
      Aplica los parámetros NumAlarmsNeDisconnected y SecondsToConsiderNeDisconnected
      a todas las alarmas con severidad distinta de CLEAR.
   -->
   <topFilter name="tags" tagsGroup="tags-config">
      <!-- Añadimos TeMIPNamespace y SecondsMaxAgeForNeAlarm como en CorteFibraV10 (adaptado) -->
      <allCondition tag="NumAlarmsNeDisconnected=2,SecondsToConsiderNeDisconnected=30,SecondsMaxAgeForNeAlarm=43200,TeMIPNamespace=vtemiplab_ns">
         <stringFilterStatement>
            <fieldName>originatingManagedEntity</fieldName>
            <operator>matches</operator>
            <fieldValue>.*</fieldValue>
         </stringFilterStatement>
         <stringFilterStatement>
            <fieldName>perceivedSeverity</fieldName>
            <operator>isNotEqual</operator>
            <fieldValue>CLEAR</fieldValue>
         </stringFilterStatement>
      </allCondition>
   </topFilter>

</filters>
